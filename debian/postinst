#!/bin/bash
set -e

# Post-installation script for dawnstar-readaloud

case "$1" in
    configure)
        # Update desktop database
        if command -v update-desktop-database &> /dev/null; then
            update-desktop-database -q /usr/share/applications 2>/dev/null || true
        fi

        # Notify user about system dependencies
        echo ""
        echo "Dawnstar ReadAloud has been installed!"
        echo ""
        echo "System dependencies (install with: sudo apt install mpg123 xclip poppler-utils):"
        echo "  - mpg123: Audio playback (recommended)"
        echo "  - xclip or wl-clipboard: Clipboard access for keyboard shortcuts"
        echo "  - poppler-utils: PDF text extraction"
        echo "  - espeak-ng: Fallback TTS engine (optional)"
        echo ""
        echo "Usage:"
        echo "  tts 'Hello world'         - Speak text"
        echo "  tts document.txt          - Read a file"
        echo "  tts https://example.com   - Read a webpage"
        echo "  ttsc --help               - Daemon client options"
        echo ""
        echo "To set up keyboard shortcuts, run:"
        echo "  python3 /usr/share/dawnstar-readaloud/configure.py"
        echo ""
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "postinst called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
