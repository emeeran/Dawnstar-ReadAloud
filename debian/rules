#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

export PYBUILD_NAME=dawnstar-readaloud
export PYBUILD_DESTDIR_python3=debian/dawnstar-readaloud/

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_clean:
	python3 setup.py clean -a || true
	rm -rf build || true

override_dh_auto_build:
	python3 setup.py build

override_dh_auto_install:
	python3 setup.py install --root=debian/dawnstar-readaloud --install-layout=deb
	# Install wrapper scripts
	install -d debian/dawnstar-readaloud/usr/bin
	install -m 755 tts debian/dawnstar-readaloud/usr/bin/tts
	install -m 755 ttsc debian/dawnstar-readaloud/usr/bin/ttsc
	install -m 755 speak_from_cursor.sh debian/dawnstar-readaloud/usr/bin/tts-speak
	install -m 755 stop_speaking.sh debian/dawnstar-readaloud/usr/bin/tts-stop
	# Install systemd service
	install -d debian/dawnstar-readaloud/usr/lib/systemd/user
	install -m 644 systemd/tts-daemon.service debian/dawnstar-readaloud/usr/lib/systemd/user/

override_dh_python3:
	dh_python3 --depends=python3

override_dh_strip:
	# Don't strip Python files

override_dh_compress:
	# Don't compress documentation
