#!/usr/bin/env python3
"""
TTS Client (ttsc)

Command-line client for the TTS daemon. Provides:
- Daemon control (start/stop/status)
- Speech commands (speak/speak-selection)
- Playback control (pause/resume/stop)
"""

import sys
import os
import subprocess
import argparse
from pathlib import Path

# Add script directory to path for imports
SCRIPT_DIR = Path(__file__).parent
sys.path.insert(0, str(SCRIPT_DIR))

from ttsd.ipc import IPCClient


def start_daemon(fork: bool = False, verbose: bool = False) -> int:
    """Start the TTS daemon."""
    daemon_script = SCRIPT_DIR / "ttsd" / "daemon.py"

    if not daemon_script.exists():
        print("Error: Daemon module not found", file=sys.stderr)
        return 1

    # Check if already running
    client = IPCClient()
    if client.is_running():
        print("Daemon is already running")
        return 0

    cmd = [sys.executable, "-m", "ttsd.daemon"]
    if verbose:
        cmd.append("-v")

    if fork:
        # Fork to background
        subprocess.Popen(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True
        )
        print("Daemon started in background")
    else:
        # Run in foreground
        os.execv(sys.executable, cmd)

    return 0


def stop_daemon() -> int:
    """Stop the TTS daemon."""
    client = IPCClient()
    if not client.is_running():
        print("Daemon is not running")
        return 0

    result = client.shutdown()
    if result.get("status") == "ok":
        print("Daemon stopped")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}", file=sys.stderr)
        return 1


def speak_text(text: str, lang: str = None, speed: str = None) -> int:
    """Queue text for speaking."""
    client = IPCClient()

    if not client.is_running():
        print("Daemon is not running. Start with: ttsc --daemon", file=sys.stderr)
        return 1

    options = {}
    if lang:
        options["lang"] = lang
    if speed:
        options["speed"] = speed

    result = client.speak(text, options)

    if result.get("status") == "ok":
        print(f"Job {result.get('job_id')} queued")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}", file=sys.stderr)
        return 1


def speak_selection(lang: str = None, speed: str = None) -> int:
    """Speak clipboard content."""
    client = IPCClient()

    if not client.is_running():
        print("Daemon is not running. Start with: ttsc --daemon", file=sys.stderr)
        return 1

    options = {}
    if lang:
        options["lang"] = lang
    if speed:
        options["speed"] = speed

    result = client.speak_selection(options)

    if result.get("status") == "ok":
        print(f"Job {result.get('job_id')} queued")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}", file=sys.stderr)
        return 1


def stop_speaking() -> int:
    """Stop current playback."""
    client = IPCClient()
    result = client.stop()

    if result.get("status") == "ok":
        print("Stopped")
        return 0
    return 0  # Stop always succeeds


def pause_speaking() -> int:
    """Pause playback."""
    client = IPCClient()
    result = client.pause()

    if result.get("status") == "ok":
        print("Paused")
        return 0
    else:
        print(f"Error: {result.get('message', 'Cannot pause')}", file=sys.stderr)
        return 1


def resume_speaking() -> int:
    """Resume playback."""
    client = IPCClient()
    result = client.resume()

    if result.get("status") == "ok":
        print("Resumed")
        return 0
    else:
        print(f"Error: {result.get('message', 'Cannot resume')}", file=sys.stderr)
        return 1


def show_status() -> int:
    """Show daemon status."""
    client = IPCClient()
    result = client.status()

    if result.get("status") != "ok":
        print("Daemon is not running")
        return 1

    data = result.get("data", {})
    print(f"State: {data.get('state', 'unknown')}")
    print(f"Queue size: {data.get('queue_size', 0)}")
    print(f"Jobs pending: {data.get('jobs_pending', 0)}")

    current = data.get("current_job")
    if current:
        print(f"Current job: {current.get('job_id')}")
        print(f"  Text: {current.get('text_preview', '')[:50]}...")
        print(f"  Progress: {current.get('progress', 0) * 100:.0f}%")

    return 0


def list_voices() -> int:
    """List available voices."""
    client = IPCClient()
    result = client.get_voices()

    if result.get("status") != "ok":
        print("Daemon is not running")
        return 1

    print("Available voices:")
    for voice in result.get("voices", []):
        print(f"  {voice['id']}: {voice['name']} ({voice['voice']})")

    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        description="TTS Client - Control the TTS daemon",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  ttsc --daemon                Start daemon in foreground
  ttsc --daemon --fork         Start daemon in background
  ttsc speak "Hello world"     Queue text for speaking
  ttsc speak-selection         Speak clipboard content
  ttsc stop                    Stop playback
  ttsc pause                   Pause playback
  ttsc resume                  Resume playback
  ttsc status                  Show daemon status
  ttsc voices                  List available voices
"""
    )

    parser.add_argument(
        "--daemon",
        action="store_true",
        help="Start the TTS daemon"
    )
    parser.add_argument(
        "--fork",
        action="store_true",
        help="Fork daemon to background (use with --daemon)"
    )
    parser.add_argument(
        "--stop-daemon",
        action="store_true",
        help="Stop the TTS daemon"
    )
    parser.add_argument(
        "-l", "--lang",
        default=None,
        help="Language for TTS (en-us, en-uk, ta)"
    )
    parser.add_argument(
        "-s", "--speed",
        default=None,
        choices=["slow", "normal", "fast"],
        help="Speech speed"
    )

    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # speak command
    speak_parser = subparsers.add_parser("speak", help="Speak text")
    speak_parser.add_argument("text", nargs="+", help="Text to speak")

    # speak-selection command
    subparsers.add_parser("speak-selection", help="Speak clipboard content")

    # stop command
    subparsers.add_parser("stop", help="Stop playback")

    # pause command
    subparsers.add_parser("pause", help="Pause playback")

    # resume command
    subparsers.add_parser("resume", help="Resume playback")

    # status command
    subparsers.add_parser("status", help="Show daemon status")

    # voices command
    subparsers.add_parser("voices", help="List available voices")

    args = parser.parse_args()

    # Handle daemon control
    if args.daemon:
        return start_daemon(fork=args.fork)

    if args.stop_daemon:
        return stop_daemon()

    # Handle commands
    if args.command == "speak":
        text = " ".join(args.text)
        return speak_text(text, lang=args.lang, speed=args.speed)

    elif args.command == "speak-selection":
        return speak_selection(lang=args.lang, speed=args.speed)

    elif args.command == "stop":
        return stop_speaking()

    elif args.command == "pause":
        return pause_speaking()

    elif args.command == "resume":
        return resume_speaking()

    elif args.command == "status":
        return show_status()

    elif args.command == "voices":
        return list_voices()

    else:
        parser.print_help()
        return 0


if __name__ == "__main__":
    sys.exit(main())
