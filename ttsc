def stop_playback(args):
    """Stop current playback."""
    client = IPCClient()
    result = client.stop()

    if result.get("status") == "ok":
        print("Stopped")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}")
        return 1


def pause_playback(args):
    """Pause current playback."""
    client = IPCClient()
    result = client.pause()

    if result.get("status") == "ok":
        print("Paused")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}")
        return 1


def resume_playback(args):
    """Resume paused playback."""
    client = IPCClient()
    result = client.resume()

    if result.get("status") == "ok":
        print("Resumed")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}")
        return 1


def main():
    parser = argparse.ArgumentParser(
        description="TTS Client - Low-latency speech synthesis via daemon"
    )
    subparsers = parser.add_subparsers(dest="command", help="Commands")

    # Daemon control
    daemon_parser = subparsers.add_parser("daemon", help="Start the daemon")
    daemon_parser.add_argument("--fork", action="store_true", help="Run in background")
    daemon_parser.add_argument("--lang", default="en-us", help="Default language")
    daemon_parser.add_argument(
        "--speed", default="normal", choices=["slow", "normal", "fast"]
    )
    daemon_parser.set_defaults(func=start_daemon)

    stop_parser = subparsers.add_parser("stop-daemon", help="Stop the daemon")
    stop_parser.set_defaults(func=stop_daemon)

    status_parser = subparsers.add_parser("status", help="Show daemon status")
    status_parser.set_defaults(func=daemon_status)

    # Speech commands
    speak_parser = subparsers.add_parser("speak", help="Speak text")
    speak_parser.add_argument("text", nargs="+", help="Text to speak")
    speak_parser.add_argument("-l", "--lang", help="Language")
    speak_parser.add_argument("-s", "--speed", help="Speed")
    speak_parser.add_argument("-v", "--verbose", action="store_true")
    speak_parser.set_defaults(func=speak_text)

    sel_parser = subparsers.add_parser("selection", help="Speak clipboard selection")
    sel_parser.add_argument("-l", "--lang", help="Language")
    sel_parser.add_argument("-s", "--speed", help="Speed")
    sel_parser.add_argument("-v", "--verbose", action="store_true")
    sel_parser.set_defaults(func=speak_selection)

    stop_play_parser = subparsers.add_parser("stop", help="Stop playback")
    stop_play_parser.set_defaults(func=stop_playback)

    pause_parser = subparsers.add_parser("pause", help="Pause playback")
    pause_parser.set_defaults(func=pause_playback)

    resume_parser = subparsers.add_parser("resume", help="Resume playback")
    resume_parser.set_defaults(func=resume_playback)

    # Legacy short options
    parser.add_argument("--daemon", action="store_true", help="Start daemon")
    parser.add_argument("--fork", action="store_true", help="Run daemon in background")
    parser.add_argument("--status", action="store_true", help="Show daemon status")

    args = parser.parse_args()

    # Handle legacy options
    if args.daemon:
        return start_daemon(args)
    if args.status:
        return daemon_status(args)

    if args.command is None:
        parser.print_help()
        return 1

    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
