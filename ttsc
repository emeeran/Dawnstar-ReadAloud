#!/usr/bin/env python3
"""
TTS Client - Command-line interface for TTS daemon.

Provides low-latency speech synthesis by communicating with a
background daemon process via Unix socket.
"""

import argparse
import os
import subprocess
import sys
from pathlib import Path

# Add parent directory to path
sys.path.insert(0, str(Path(__file__).parent))

from ttsd import TTSDaemon, IPCClient
from ttsd.ipc import UnixSocketServer


def start_daemon(args):
    """Start the TTS daemon."""
    # Check if already running
    client = IPCClient()
    if client.is_running():
        print("Daemon is already running")
        return 1

    # Start daemon in background
    if args.fork:
        # Fork to background
        script_dir = Path(__file__).parent
        daemon_script = script_dir / ".venv" / "bin" / "python" / "-m" / "ttsd"

        # Use subprocess to start daemon
        subprocess.Popen(
            [
                script_dir / ".venv" / "bin" / "python",
                "-m",
                "ttsd",
                "--lang", args.lang,
                "--speed", args.speed,
            ],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        print("Daemon started in background")
        return 0
    else:
        # Run in foreground
        from ttsd.daemon import main
        main()


def stop_daemon(args):
    """Stop the TTS daemon."""
    client = IPCClient()
    result = client.shutdown()

    if result.get("status") == "ok":
        print("Daemon stopped")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}")
        return 1


def daemon_status(args):
    """Show daemon status."""
    client = IPCClient()
    result = client.status()

    if result.get("status") == "ok":
        data = result.get("data", {})
        print(f"State: {data.get('state', 'unknown')}")
        print(f"Queue size: {data.get('queue_size', 0)}")
        print(f"Jobs pending: {data.get('jobs_pending', 0)}")

        current = data.get("current_job")
        if current:
            print(f"Current job: {current.get('job_id')}")
            print(f"  Progress: {current.get('progress', 0) * 100:.0f}%")
            print(f"  Text: {current.get('text_preview', '')[:50]}...")
        return 0
    else:
        print(f"Daemon not running: {result.get('message', '')}")
        return 1


def speak_text(args):
    """Speak text via daemon."""
    client = IPCClient()

    if not client.is_running():
        print("Daemon not running. Start with: ttsc --daemon")
        return 1

    text = " ".join(args.text)
    options = {}
    if args.lang:
        options["lang"] = args.lang
    if args.speed:
        options["speed"] = args.speed

    result = client.speak(text, options)

    if result.get("status") == "ok":
        if args.verbose:
            print(f"Job {result.get('job_id')} queued")
        return 0
    else:
        print(f"Error: {result.get('message', 'Unknown error')}")
        return 1


def speak_selection(args):
    """Speak clipboard selection via daemon."""
    client = IPCClient()

    if not client.is_running():
        print("Daemon not running. Start with: ttsc --daemon")
        return 1

    options = {}
    if args.lang:
        options["lang"] = args.lang
    if args.speed:
        options["speed"] = args.speed

    result = client.speak_selection(options)

    if result.get("status") == "ok":
        if args.verbose:
