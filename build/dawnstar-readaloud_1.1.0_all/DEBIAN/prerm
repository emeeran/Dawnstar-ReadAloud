#!/bin/bash
set -e

# Pre-removal script for dawnstar-readaloud

case "$1" in
    remove|upgrade|deconfigure)
        # Stop the daemon if running
        if [ -x /usr/bin/ttsc ]; then
            /usr/bin/ttsc stop 2>/dev/null || true
        fi

        # Kill any active audio playback
        pkill -f "mpg123.*tts" 2>/dev/null || true
        pkill -f "python3.*tts" 2>/dev/null || true
        ;;

    abort-upgrade|failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
