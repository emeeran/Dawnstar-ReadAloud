#!/bin/bash
# Quick launcher script for TTS app

# Determine script location
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Search for the app.py and core module
if [ -f "$SCRIPT_DIR/app.py" ]; then
    APP_PATH="$SCRIPT_DIR/app.py"
    VENV_DIR="$SCRIPT_DIR/.venv"
elif [ -f "/usr/lib/dawnstar-readaloud/app.py" ]; then
    APP_PATH="/usr/lib/dawnstar-readaloud/app.py"
    VENV_DIR="/usr/lib/dawnstar-readaloud/.venv"
else
    echo "Error: Could not find app.py in $SCRIPT_DIR or /usr/lib/dawnstar-readaloud/"
    exit 1
fi

# Check for virtual environment
if [ -f "$VENV_DIR/bin/python" ]; then
    PYTHON_EXE="$VENV_DIR/bin/python"
else
    # Fallback to system python
    PYTHON_EXE=$(which python3)
fi

# Run the app with all arguments passed through
exec "$PYTHON_EXE" "$APP_PATH" "$@"
