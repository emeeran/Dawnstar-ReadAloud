#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure|failed-upgrade)
        # Stop TTS daemon before removal
        systemctl --user stop tts-daemon.service 2>/dev/null || true
        # Kill any active audio playback
        pkill -f "mpg123" 2>/dev/null || true
        pkill -f "paplay" 2>/dev/null || true
        pkill -f "cvlc" 2>/dev/null || true
        pkill -f "ffplay" 2>/dev/null || true
        ;;

    abort-upgrade|abort-remove|abort-deconfigure)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        ;;
esac

#DEBHELPER#

exit 0
