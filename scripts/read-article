#!/usr/bin/env python3
"""
Read web article aloud - extracts main content, skips navigation/ads.

Usage:
    ./read-article https://example.com/article
"""

import sys
import re
import urllib.request
from pathlib import Path

# Add parent directory for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

try:
    from bs4 import BeautifulSoup
    HAS_BS4 = True
except ImportError:
    HAS_BS4 = False


# Elements to skip (navigation, ads, sidebars, etc.)
SKIP_TAGS = {
    'nav', 'header', 'footer', 'aside', 'script', 'style',
    'form', 'iframe', 'noscript', 'svg', 'button', 'input',
    'select', 'textarea', 'menu', 'menuitem'
}

# Class/ID patterns that indicate non-content areas
SKIP_PATTERNS = [
    r'nav', r'menu', r'sidebar', r'footer', r'header',
    r'comment', r'share', r'social', r'related', r'recommend',
    r'advertisement', r'ad-', r'ads-', r'promo', r'sponsor',
    r'breadcrumb', r'pagination', r'author-info', r'tag[s]?$',
    r'newsletter', r'subscribe', r'popup', r'modal', r'overlay',
    r'cookie', r'gdpr', r'privacy', r'login', r'signup',
    r'search', r'filter', r'sort', r'widget'
]

# Patterns that indicate main content
CONTENT_PATTERNS = [
    r'article', r'content', r'post', r'entry', r'story',
    r'body', r'main', r'text', r'blog', r'news'
]


def clean_text(text: str) -> str:
    """Clean and normalize text."""
    # Remove excessive whitespace
    text = re.sub(r'\s+', ' ', text)
    # Remove URLs
    text = re.sub(r'https?://\S+', '', text)
    # Remove email addresses
    text = re.sub(r'\S+@\S+', '', text)
    # Remove common junk
    text = re.sub(r'Subscribe\s*$', '', text, flags=re.IGNORECASE)
    text = re.sub(r'Newsletter\s*$', '', text, flags=re.IGNORECASE)
    return text.strip()


def should_skip_element(elem) -> bool:
    """Check if element should be skipped."""
    if elem is None or elem.name is None:
        return True

    # Check tag name
    if elem.name in SKIP_TAGS:
        return True

    # Check class and id attributes
    classes = ' '.join(elem.get('class', []) or [])
    elem_id = elem.get('id', '') or ''
    combined = f"{classes} {elem_id}".lower()

    for pattern in SKIP_PATTERNS:
        if re.search(pattern, combined, re.IGNORECASE):
            return True

    return False


def score_element(elem) -> int:
    """Score an element's likelihood of being main content."""
    if elem is None or elem.name is None:
        return 0

    score = 0

    # Check tag name
    if elem.name in ['article', 'main']:
        score += 50
    elif elem.name == 'div':
        score += 10

    # Check class/id for content hints
    classes = ' '.join(elem.get('class', []) or [])
    elem_id = elem.get('id', '') or ''
    combined = f"{classes} {elem_id}".lower()

    for pattern in CONTENT_PATTERNS:
        if re.search(pattern, combined, re.IGNORECASE):
            score += 30

    # Score by text length (more text = more likely main content)
    try:
        text_len = len(elem.get_text(strip=True))
        score += min(text_len / 50, 100)  # Cap at 100
    except:
        pass

    # Penalize for too many links (nav areas have lots of links)
    try:
        links = elem.find_all('a')
        text = elem.get_text(strip=True)
        if text:
            link_density = len(links) / (len(text.split()) + 1)
            if link_density > 0.3:
                score -= 30
    except:
        pass

    # Bonus for paragraph tags (article content has <p>)
    try:
        paragraphs = elem.find_all('p')
        score += len(paragraphs) * 5
    except:
        pass

    return score


def extract_article(html: str, url: str = "") -> str:
    """Extract main article content from HTML."""
    if not HAS_BS4:
        print("Error: beautifulsoup4 required. Install with: pip install beautifulsoup4")
        return ""

    soup = BeautifulSoup(html, 'html.parser')

    # Collect elements to remove (don't decompose while iterating)
    to_remove = []

    # Find skip elements by tag
    for tag in SKIP_TAGS:
        to_remove.extend(soup.find_all(tag))

    # Find elements matching skip patterns
    for elem in soup.find_all(True):
        try:
            if elem and elem.name:
                classes = ' '.join(elem.get('class', []) or [])
                elem_id = elem.get('id', '') or ''
                combined = f"{classes} {elem_id}".lower()

                for pattern in SKIP_PATTERNS:
                    if re.search(pattern, combined, re.IGNORECASE):
                        to_remove.append(elem)
                        break
        except:
            continue

    # Now remove all at once
    for elem in to_remove:
        try:
            elem.decompose()
        except:
            pass

    # Try to find main content area
    candidates = []

    # Look for semantic elements first
    for tag in ['article', 'main', '[role="main"]']:
        found = soup.select(tag)
        candidates.extend(found)

    # Score all divs/sections and pick best
    for elem in soup.find_all(['div', 'section']):
        try:
            if elem and len(elem.get_text(strip=True)) > 200:
                candidates.append(elem)
        except:
            continue

    if not candidates:
        # Fallback: use body
        main = soup.find('body')
    else:
        # Pick highest scored element
        main = max(candidates, key=score_element, default=soup.find('body'))

    if not main:
        return ""

    # Extract text from paragraphs and headings
    parts = []
    for elem in main.find_all(['h1', 'h2', 'h3', 'h4', 'p', 'li']):
        try:
            text = clean_text(elem.get_text())
            # Skip very short fragments (likely junk)
            if len(text) > 20:
                parts.append(text)
        except:
            continue

    return ' '.join(parts)


def main():
    if len(sys.argv) < 2:
        print("Usage: ./read-article <url>")
        print("Reads main article content from a web page.")
        sys.exit(1)

    url = sys.argv[1]

    # Validate URL
    if not url.startswith(('http://', 'https://')):
        url = 'https://' + url

    print(f"Fetching: {url}")

    # Fetch HTML
    try:
        req = urllib.request.Request(
            url,
            headers={'User-Agent': 'Mozilla/5.0 (compatible; TTS-Reader/1.0)'}
        )
        with urllib.request.urlopen(req, timeout=30) as response:
            html = response.read().decode('utf-8', errors='ignore')
    except Exception as e:
        print(f"Error fetching URL: {e}")
        sys.exit(1)

    print("Extracting article content...")

    # Extract article
    article = extract_article(html, url)

    if not article:
        print("Could not extract article content")
        sys.exit(1)

    # Show stats
    words = len(article.split())
    chars = len(article)
    print(f"Found {words} words ({chars} characters)")

    # Read aloud using TTS
    import app

    print("Speaking...")
    config = app.TTSConfig()

    # Chunk the text
    chunks = app.ContentExtractor.chunk_text(article)

    tts = app.TTSEngine(config)
    for i, chunk in enumerate(chunks, 1):
        if len(chunks) > 1:
            print(f"[{i}/{len(chunks)}]", end=" ", flush=True)
        audio = tts.generate(chunk)
        if audio:
            app.AudioPlayer.play(audio, config)

    if len(chunks) > 1:
        print()  # Newline after progress

    print("Done.")


if __name__ == "__main__":
    main()
